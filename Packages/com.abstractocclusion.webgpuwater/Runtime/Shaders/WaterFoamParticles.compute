// WebGL Water - GPU foam particles (KWS-inspired)
//
// Particles spawn on the GPU where the sim's foam/turbulence is strong, drift with
// the surface flow, and are drawn by FoamParticles.shader straight from the buffer
// (no CPU round trip). WebGPU-safe by construction:
//   - no Append/Consume buffers: a ring cursor advanced with InterlockedAdd,
//   - the sim state is read with Load + manual bilinear (r32/float RTs are not
//     filterable on WebGPU),
//   - fixed-capacity pool; dead slots are skipped by the vertex shader.
//
// Two particle kinds share one pool:
//   KIND_SURFACE: floats on the water, dragged by the local flow + wind.
//   KIND_SPRAY:   ballistic droplets thrown off strong turbulence; on landing they
//                 convert to KIND_SURFACE and keep drifting as foam.

#pragma kernel BeginFrame
#pragma kernel Spawn
#pragma kernel SpawnBurst
#pragma kernel Update
#pragma kernel ClearDensity
#pragma kernel RasterizeDensity

// Ocean-only: adds the FFT whitecap cascade as a second spawn source (breaking-crest foam). Off for
// pools/bounded bodies, so the cascade texture is never declared or bound on those dispatches.
#pragma multi_compile _ OCEAN_CREST_FOAM

#include "WaterVolume.hlsl"     // pool/window <-> world frame (same uniforms as the render side)
#include "WaterFoamCommon.hlsl" // FoamParticleEnvelope: shared with the quad render
#include "WaterSurfWaves.hlsl"  // surf breaker fronts: plunging-lip spray source (uniforms set by
                                // WaterSimulation.ShoreFoamState.BindTo - compute sees no globals)
// Shared particle plumbing: PCG hash + the Layer A shore-field fetch (uniforms, textures
// and the ONE fail-fast sampler both particle computes use).
#define WATER_PARTICLE_SHORE_FIELD 1
#include "WaterParticleCommon.hlsl"

// MUST equal WaterFoamParticles.SpawnThreadGroupSize / UpdateThreadGroupSize (C#).
#define SPAWN_THREAD_GROUP_SIZE  8
#define UPDATE_THREAD_GROUP_SIZE 64

static const float KIND_SURFACE = 0.0;
static const float KIND_SPRAY   = 1.0;

// Counters buffer layout. MUST match WaterFoamParticles.CounterCount (C#).
static const uint COUNTER_RING_CURSOR = 0; // ever-increasing spawn cursor (ring index)
static const uint COUNTER_FRAME_SPAWNS = 1; // turbulence spawns this frame (budget check)
static const uint COUNTER_BURST_SPAWNS = 2; // burst droplets this frame (own budget below)

// Burst droplets get their OWN per-frame budget = capacity / this (they are event-driven
// and must not starve behind the turbulence budget, but 16 requests x 64 droplets could
// previously recycle a quarter of a small pool in one frame, killing living foam).
static const uint BURST_FRAME_CAP_DIVISOR = 4;

// Spray landing: below this height offset the droplet becomes surface foam.
static const float SPRAY_LANDING_EPSILON = 0.005;
// Landing keeps a fraction of the horizontal speed (energy lost to the impact).
static const float SPRAY_LANDING_KEEP = 0.4;
// Kill particles this far outside the active sim frame (pool or window), in
// normalised units; a little slack so foam can hug the walls before dying.
static const float FRAME_KILL_MARGIN = 0.02;
// Window-edge fade band (normalised frame units, measured inward from the edge): inside
// it a particle AGES faster (up to FRAME_FADE_AGE_BOOST x at the very edge), so its life
// envelope fades it out before the hard kill above ever fires. Without this, the kill
// line of the camera-following window sweeps through world-anchored foam and reads as
// "the foam cloud is glued to the camera" (same defect class the roller's world snap
// fixed). The hard kill stays as the backstop where the frame has no sim data.
static const float FRAME_FADE_BAND = 0.15;
static const float FRAME_FADE_AGE_BOOST = 3.0;

// World-anchored spawn identity: spawn decisions are keyed on a fixed WORLD lattice
// instead of window texel ids, so what emits belongs to the water surface, not to
// wherever the camera-following sim window happens to sit this frame. Cell edge = one
// sim texel, floored so ultra-fine sims don't alias into sub-lattice noise.
static const float SPAWN_CELL_MIN_METERS = 0.25;
// KWS keep-alive floor (FOAM_MIN_LOD_COUNT idiom): a sparse dusting of cells emits even
// beyond the distance-LOD range, so foam already exists when the camera turns or
// approaches instead of visibly popping in around it.
static const float SPAWN_LOD_KEEP_ALIVE = 0.02;
// Distance-LOD falloff shape (KWS pow5-shoulder idiom): FULL density out to this fraction
// of the range, then a smooth shoulder down to the keep-alive floor. The old linear
// ticket-vs-distance curve started thinning right at the camera (~half the cells rejected
// only 25% into the range), so the foam field read as a soft blob whose density gradient
// travelled with the camera - especially as the connected screen-space density veil,
// where the gradient is one visible shape instead of scattered sprites.
static const float SPAWN_LOD_PLATEAU = 0.6;

// One particle = 48 bytes. MUST match FoamParticle in FoamParticles.shader and
// the stride in WaterFoamParticles.cs.
struct FoamParticle
{
    float3 worldPos; // world xz; y = height offset ABOVE the local water surface
    float3 velocity; // world units/sec (y used while KIND_SPRAY)
    float  age;      // seconds since spawn
    float  life;     // seconds; <= 0 marks a dead slot
    float  size;     // world half-size of the quad
    float  seed;     // 0..1, fixed per particle (sprite variant, yaw, jitter)
    float  kind;     // KIND_SURFACE or KIND_SPRAY
    float  strength; // foam amount at spawn, scales opacity
};

RWStructuredBuffer<FoamParticle> Particles;
RWStructuredBuffer<uint> Counters;

// Sim inputs (same textures the Foam kernel reads).
Texture2D<float4> Sim;      // (height, velocity, normal.x, normal.z)
Texture2D<float>  FoamTex;  // foam amount (R)

float _Size;              // sim grid resolution
uint  _Capacity;          // particle pool size (power of two)
uint  _FrameSeed;         // per-frame random salt
float _DeltaTime;

// Spawn tuning
float _SpawnThreshold;    // foam level below which nothing spawns
float _SpawnRate;         // expected spawns / second / world-unit^2 at foam = 1
uint  _MaxSpawnPerFrame;  // hard budget per frame
float _SprayChance;       // 0..1 fraction of spawns thrown as ballistic spray
float _SprayLaunchSpeed;  // world units/sec initial upward speed of spray
float _LifeMin, _LifeMax; // seconds
float _SizeMin, _SizeMax; // world units
float _SizeHeroPower;     // >= 1; KWS pow-distribution: most particles small, rare heroes
float _TexelWorldArea;    // world-space area covered by one sim texel

// Update tuning
float _Gravity;           // world units/sec^2 (positive down)
float _FlowDrift;         // world units/sec of drift per unit of surface slope
float2 _WindDrift;        // constant world-space xz drift from the wind
float _Drag;              // 1/sec velocity relaxation toward the driven speed

// ---- Screen-space density foam (KWS: particles accumulate into a density buffer instead of
// drawing overlapping quads; a fullscreen composite turns density into connected, lit foam). ----
RWStructuredBuffer<uint> DensityBuffer; // per density texel: fixed-point accumulated foam weight
RWStructuredBuffer<uint> DensityDepth;  // per density texel: min eye depth (millimetres) for occlusion
RWStructuredBuffer<uint> TileCounts;    // per screen tile: spray spawns this frame (budget)

uint2    _DensitySize;       // density buffer dimensions (a fraction of the camera target)
float4x4 _DensityViewProj;   // camera GPU view-projection (same matrix family the render uses)
float    _DensityProj11;     // projection [1][1]: vertical focal term for projected-size estimates
float    _DensityWeightScale;// fixed-point units per 1.0 of foam weight

// Spawn quality (KWS trio)
float2 _SpawnCameraXZ;       // camera ground position for the stochastic distance LOD
float  _SpawnMaxDistance;    // metres; beyond this no particles spawn. 0 = LOD disabled
float  _TileBudgetEnabled;   // 1 when a camera is available to project spray spawns
uint   _SprayTileCap;        // max spray spawns per screen tile per frame

// Wave occlusion for the density splat is NOT done here: the composite writes the
// splatted min depth to SV_Depth and z-tests LEqual against the live depth buffer,
// which already contains every wave crest (the water surface is ZWrite On and draws
// before the veil). Exact, per pixel, and free per particle - an analytic camera-ray
// march against the composed surface height was tried and rejected (4x SurfaceWorldY
// per particle per frame, and crests between samples slipped through).

// Depth quantisation for the InterlockedMin buffer: millimetres in uint.
static const float DEPTH_TO_MM = 1000.0;
// Density buffer cleared depth (no particle) - uint max.
static const uint DEPTH_CLEAR = 0xFFFFFFFFu;
// Splat footprint clamp (density texels). Small pool sizes keep the per-particle loop bounded;
// the composite's dilation closes any remaining pinholes between splats.
static const int SPLAT_RADIUS_MAX = 3;
// Screen tile grid for the spray budget (KWS buckets splash into 64px tiles; a fixed 16x16
// grid is resolution-independent and keeps the counter buffer tiny).
static const uint TILE_GRID = 16;
// Spawn-probability boost per unit of local velocity shear (wake edges emit more).
static const float SPAWN_SHEAR_BOOST = 4.0;

// Surf plunging-lip spray (CURL-3, the KWS crash moment): a spawn on a cresting PLUNGING front is
// forced to ballistic spray thrown shoreward off the lip. The gate reads the front's canonical
// breaker signal (cresting-lip line, plunge-amplified, surge-killed - WaterSurfWaves.hlsl), so
// spilling shelves and surging cliffs throw nothing. The whitewash the shore injection already
// writes into the foam buffer covers spawn PROBABILITY; these only shape what spawns there.
static const float SURF_SPRAY_MIN_LIP = 0.3;
static const float SURF_SPRAY_THROW_SPEED = 6.0;
// (Shore border feather + deep sentinel now come from WaterParticleCommon.hlsl:
// PARTICLE_SHORE_BORDER_FEATHER / PARTICLE_SHORE_DEEP_SENTINEL - one copy for both
// particle computes.)
// Matches OCEAN_FFT_CASCADE_WAVELENGTH_FRACTION (WaterLargeWaves.hlsl): a cascade's shore
// attenuation uses one representative wavelength = this fraction of its domain size.
static const float CASCADE_WAVELENGTH_FRACTION_SIM = 0.25;

// ---- CPU-event splash bursts (spray unification): rigidbody impacts and mouse splashes
// queue burst requests on the CPU; the SpawnBurst kernel throws KIND_SPRAY droplets from
// the same pool, so ALL airborne droplets share one tech path + one look (the Shuriken
// system keeps only the one-shot crown flipbook). MUST match BurstRequest in
// WaterFoamParticles.cs (48 bytes) and MAX_BURST_DROPLETS <= the kernel thread count. ----
struct BurstRequest
{
    float3 center;   // world surface position of the impact
    float  radius;   // world ring radius droplets spawn on
    float  strength; // 0..1 impact strength: scales opacity via particle.strength
    float  upSpeed;  // world units/sec base upward pop
    float  outSpeed; // world units/sec base outward throw
    float  seed;     // per-burst random salt
    float  count;    // droplets requested (<= MAX_BURST_DROPLETS)
    float3 _pad;
};
StructuredBuffer<BurstRequest> BurstRequests;
uint _BurstRequestCount;

static const uint  MAX_BURST_DROPLETS = 64;   // one thread group per request
// Per-droplet jitters, matching the legacy Shuriken burst's feel. MUST match the
// counterpart consts in WaterSplashEmitter.cs (the fallback path) - guarded by
// WaterWaveConstantsValidator, so a retune on either side is reported on editor load.
static const float BURST_OUT_JITTER_MIN = 0.4;
static const float BURST_OUT_JITTER_MAX = 1.0;
static const float BURST_UP_JITTER_MIN = 0.5;
static const float BURST_UP_JITTER_MAX = 1.2;
static const float BURST_SPAWN_HEIGHT = 0.01;  // just above the surface, never submerged
static const float BURST_RING_RADIUS_SCALE = 0.5; // spawn inside half the impact radius

// ---- Foam motion richness (KWS curl + clumping): floating foam is swirled by a
// divergence-free curl field and gently attracted toward noise maxima, so it gathers
// into streaks/patches instead of staying a uniform sprinkle. ----
float _FoamTime; // slow world clock for the noise drift
static const float FOAM_NOISE_SCALE   = 0.7;   // noise features per world metre
static const float FOAM_NOISE_DRIFT   = 0.05;  // field drift speed (keeps clumps alive)
static const float FOAM_CURL_SPEED    = 0.06;  // world units/sec of swirl
static const float FOAM_CLUMP_SPEED   = 0.04;  // world units/sec of attraction

#ifdef OCEAN_CREST_FOAM
// FFT spatial cascade (.y = height) + amplitude, so the density splat can place foam on the
// real swell height the way FoamParticles.shader's vertex glue does with LargeBodyWaveHeight.
Texture2DArray<float4> _OceanFftSpatial;
SamplerState sampler_OceanFftSpatial;
float _OceanFftAmplitude;
#endif

#ifdef OCEAN_CREST_FOAM
// Ocean whitecap cascade (bound per-frame from WaterFoamParticles.cs; same array the surface samples).
Texture2DArray<float4> _OceanFftNormal;
SamplerState sampler_OceanFftNormal;
float4 _OceanFftDomainSizes;   // metres per cascade
float  _OceanFftCascadeCount;  // active cascades (<= 4)
float2 _CrestRoll;             // world xz drift (m/s) along the wave direction: foam rolls with the crest
#define OCEAN_FFT_MAX_CASCADES 4

// Sum the accumulated whitecap foam (.w) across cascades at a world xz. No distance fade here (the
// spawn window is already near-camera): we want to emit wherever the surface is actually breaking.
float OceanCrestFoamAt(float2 worldXZ)
{
    float foam = 0.0;
    for (int c = 0; c < OCEAN_FFT_MAX_CASCADES; c++)
    {
        float active = (c < (int)_OceanFftCascadeCount) ? 1.0 : 0.0;
        float slice = min((float)c, _OceanFftCascadeCount - 1.0);
        float2 uv = worldXZ / max(_OceanFftDomainSizes[c], 1e-3);
        foam += active * _OceanFftNormal.SampleLevel(sampler_OceanFftNormal, float3(uv, slice), 0).w;
    }
    return saturate(foam);
}
#endif

// ---------------------------------------------------------------- helpers
int2 ClampTexel(int2 p) { return clamp(p, int2(0, 0), int2((int)_Size - 1, (int)_Size - 1)); }

// Pcg/Rand01 come from WaterParticleCommon.hlsl (shared with WaterSurfRoller.compute).

// World-lattice key of a spawn candidate. Two window texels that cover the same world
// cell make the SAME rolls, and a texel keeps its rolls while the window glides under
// it - the emission pattern is anchored to the water, not the camera.
uint2 WorldSpawnKey(float2 worldXZ)
{
    float cellMeters = max(sqrt(_TexelWorldArea), SPAWN_CELL_MIN_METERS);
    return (uint2)(int2)floor(worldXZ / cellMeters); // negative cells wrap deterministically
}

// Normalised sim-frame coords (.xz in [-1,1]) of a world point: window frame when
// windowed, else the whole pool. Mirrors the fcoord convention of WaterSurface.
float2 WorldToSimNorm(float3 world)
{
    return (_SimWindowed < 0.5) ? WorldToPool(world).xz : WorldToSim(world).xz;
}

// World position of a sim texel centre on the surface plane (y = 0).
float3 TexelToWorld(int2 texel)
{
    float2 norm = ((float2(texel) + 0.5) / _Size) * 2.0 - 1.0;
    if (_SimWindowed < 0.5)
        return PoolToWorld(float3(norm.x, 0.0, norm.y));
    return _SimCenter + mul(VolumeRot(), float3(norm.x, 0.0, norm.y) * SimExtentSafe());
}

// Manual bilinear fetch of the sim state at normalised frame coords.
float4 SampleSim(float2 simNorm)
{
    float2 st = (simNorm * 0.5 + 0.5) * _Size - 0.5;
    int2   s0 = (int2)floor(st);
    float2 t  = st - float2(s0);
    float4 c00 = Sim.Load(int3(ClampTexel(s0 + int2(0, 0)), 0));
    float4 c10 = Sim.Load(int3(ClampTexel(s0 + int2(1, 0)), 0));
    float4 c01 = Sim.Load(int3(ClampTexel(s0 + int2(0, 1)), 0));
    float4 c11 = Sim.Load(int3(ClampTexel(s0 + int2(1, 1)), 0));
    return lerp(lerp(c00, c10, t.x), lerp(c01, c11, t.x), t.y);
}

// Smooth value noise from the shared PCG hash (no texture needed at particle counts):
// hashed lattice corners, hermite-blended. Range [0,1).
float FoamValueNoise(float2 p)
{
    float2 cell = floor(p);
    float2 f = p - cell;
    f = f * f * (3.0 - 2.0 * f);
    uint2 c = (uint2)(int2)cell; // negative cells wrap deterministically
    float n00 = Rand01(c, 0x51ED270Bu);
    float n10 = Rand01(c + uint2(1u, 0u), 0x51ED270Bu);
    float n01 = Rand01(c + uint2(0u, 1u), 0x51ED270Bu);
    float n11 = Rand01(c + uint2(1u, 1u), 0x51ED270Bu);
    return lerp(lerp(n00, n10, f.x), lerp(n01, n11, f.x), f.y);
}

// Central-difference gradient of the value noise (noise-space units).
float2 FoamNoiseGrad(float2 p)
{
    const float eps = 0.25;
    float gx = FoamValueNoise(p + float2(eps, 0.0)) - FoamValueNoise(p - float2(eps, 0.0));
    float gy = FoamValueNoise(p + float2(0.0, eps)) - FoamValueNoise(p - float2(0.0, eps));
    return float2(gx, gy) / (2.0 * eps);
}

// Project a world position through the camera. Returns false when behind the camera.
// uv is OUR OWN convention (ndc * 0.5 + 0.5, no platform flip): the density composite
// derives its uv from the SAME ndc math, so the two sides agree on every backend by
// construction. eyeDepth = clip.w (linear metres, perspective).
bool ProjectToScreen(float3 world, out float2 uv, out float eyeDepth)
{
    float4 clip = mul(_DensityViewProj, float4(world, 1.0));
    uv = 0.0; eyeDepth = 0.0;
    if (clip.w <= 1e-4) return false;
    uv = (clip.xy / clip.w) * 0.5 + 0.5;
    eyeDepth = clip.w;
    return true;
}

// ---- Layer A shore field for the surf-lip spray. The uniforms, textures and the raw
// fail-fast fetch live in WaterParticleCommon.hlsl (shared with WaterSurfRoller.compute);
// only the shoal-band depth is particular to this compute's height glue.
float _ShoreShoalDepth;      // shoal band depth (m) - drives the ShoalWeightSim replica below

// Replica of ShoalWeight() in WaterShore.hlsl - KEEP IN SYNC (that header declares sampler2D
// objects, which a compute kernel cannot include; the function itself is pure math).
float ShoalWeightSim(float depth, float wavelength)
{
    float clamped = max(depth, 0.0);
    float raw = saturate(2.0 * clamped / max(wavelength, 1e-3));
    float band = max(_ShoreShoalDepth, 1e-3);
    float deep = smoothstep(0.35 * band, band, clamped);
    return lerp(raw, 1.0, deep);
}

// One shore-field fetch + the canonical front evaluation at a world xz. Inert (deep water, zero
// influence, zero surf) off-field or while the shore layer is off - callers can use the outputs
// unconditionally. Built on the shared fail-fast fetch: a degenerate SDF direction is now inert
// here too, matching the roller (the old local copy pressed on with toShore = 0).
SurfWaveSample SurfSampleAt(float2 worldXZ, out float shoreDepth, out float shoreInfluence,
                            out float2 toShore)
{
    float sdfDist, tanBeta;
    if (!ParticleSampleShoreField(worldXZ, shoreDepth, sdfDist, toShore, tanBeta, shoreInfluence))
        return SurfWaveSampleInert();
    return EvaluateSurfWaves(worldXZ, shoreDepth, sdfDist, toShore, tanBeta, shoreInfluence,
                             _ShoreFoamTime);
}

// The surf front's breaker-lip weight + local toward-shore direction at a world xz.
float SurfLipAt(float2 worldXZ, out float2 toShore)
{
    float depthUnused;
    float influenceUnused;
    return SurfSampleAt(worldXZ, depthUnused, influenceUnused, toShore).breaker;
}

// World-space surface height under a floating particle: the same "glue to the animated
// surface" the quad vertex does, minus the small analytic wind-wave layer (cm-scale;
// compute has no wave globals). Pond: sim heightfield. Ocean: summed FFT cascades.
float SurfaceWorldY(float3 worldPos, float2 simNorm)
{
    float surfaceY;
    // Coastline: the rendered surface shoals the swell near shore, fades it under the surf
    // fronts and adds the fronts on top - the density glue must do the same or shore-zone foam
    // rasterizes at the un-shoaled open-water height (mirrors the shader's FFT branch of
    // LargeBodyWaveHeight, built from the compute-safe replicas above). Inert off-shore.
    float shoreDepth;
    float shoreInfluence;
    float2 toShoreUnused;
    SurfWaveSample surfGlue = SurfSampleAt(worldPos.xz, shoreDepth, shoreInfluence, toShoreUnused);
#ifdef OCEAN_CREST_FOAM
    float height = 0.0;
    for (int c = 0; c < OCEAN_FFT_MAX_CASCADES; c++)
    {
        float active = (c < (int)_OceanFftCascadeCount) ? 1.0 : 0.0;
        float slice = min((float)c, _OceanFftCascadeCount - 1.0);
        float domain = max(_OceanFftDomainSizes[c], 1e-3);
        float2 uv = worldPos.xz / domain;
        float cascadeShoal = lerp(1.0, ShoalWeightSim(shoreDepth,
                                                      domain * CASCADE_WAVELENGTH_FRACTION_SIM),
                                  shoreInfluence);
        height += active * cascadeShoal
                * _OceanFftSpatial.SampleLevel(sampler_OceanFftSpatial, float3(uv, slice), 0).y;
    }
    surfaceY = _VolumeCenter.y
             + height * _OceanFftAmplitude * SurfAmbientWeight(surfGlue.mask)
             + surfGlue.height;
#else
    // Sim height is stored in pool units; the volume's vertical extent maps it to metres.
    // The surf fronts ride on top (they are analytic surface geometry, not sim state).
    float poolY = SampleSim(simNorm).r;
    surfaceY = _VolumeCenter.y + poolY * VolumeExtentSafe().y + surfGlue.height;
#endif
    return surfaceY;
}

// ---------------------------------------------------------------- kernels
// 64 threads x 4 groups = 256: clears the spray tile budget; thread 0 also resets the
// per-frame spawn counter. MUST be dispatched with TILE_GRID*TILE_GRID/64 groups.
[numthreads(64, 1, 1)]
void BeginFrame(uint3 id : SV_DispatchThreadID)
{
    if (id.x == 0)
    {
        Counters[COUNTER_FRAME_SPAWNS] = 0;
        Counters[COUNTER_BURST_SPAWNS] = 0;
    }
    if (id.x < TILE_GRID * TILE_GRID) TileCounts[id.x] = 0;
}

// One thread per sim texel: roll a spawn where foam exceeds the threshold. The
// probability is normalised by the texel's world area, so particle density (per
// square metre of foamy water) is independent of grid resolution and body size.
[numthreads(SPAWN_THREAD_GROUP_SIZE, SPAWN_THREAD_GROUP_SIZE, 1)]
void Spawn(uint3 id : SV_DispatchThreadID)
{
    int2 texel = int2(id.xy);
    float3 texelWorld = TexelToWorld(texel);
    float foam = FoamTex.Load(int3(texel, 0));
#ifdef OCEAN_CREST_FOAM
    // Add breaking-crest foam from the FFT cascade, sampled at this texel's world position. max() so a
    // texel that is both interaction-foamy and on a crest still emits at the stronger of the two.
    foam = max(foam, OceanCrestFoamAt(texelWorld.xz));
#endif
    float excess = foam - _SpawnThreshold;
    if (excess <= 0.0) return;

    // Stochastic distance LOD (KWS): spawn probability falls with camera distance. The
    // LOD ticket is FIXED per world cell (no frame seed): as the camera moves, each cell
    // switches on/off at its own stable distance instead of the whole density blob being
    // re-rolled around the camera every frame. The plateau keeps density FULL out to
    // SPAWN_LOD_PLATEAU of the range - inside it, camera motion changes nothing at all -
    // and the shoulder then thins smoothly to the keep-alive dusting beyond the range.
    uint2 spawnKey = WorldSpawnKey(texelWorld.xz);
    if (_SpawnMaxDistance > 0.0)
    {
        float distNorm = saturate(distance(texelWorld.xz, _SpawnCameraXZ) / _SpawnMaxDistance);
        float thinning = smoothstep(SPAWN_LOD_PLATEAU, 1.0, distNorm);
        float lodTicket = Rand01(spawnKey, 0x27D4EB2Du);
        if (lodTicket + SPAWN_LOD_KEEP_ALIVE < thinning) return;
    }

    // Shear boost: wake edges / interactor rims (where moving water borders still water)
    // emit more than uniformly-moving patches. Same measure the sim's foam gen uses.
    float vL = Sim.Load(int3(ClampTexel(texel + int2(-1, 0)), 0)).g;
    float vR = Sim.Load(int3(ClampTexel(texel + int2( 1, 0)), 0)).g;
    float vD = Sim.Load(int3(ClampTexel(texel + int2( 0,-1)), 0)).g;
    float vU = Sim.Load(int3(ClampTexel(texel + int2( 0, 1)), 0)).g;
    float shear = length(float2(vR - vL, vU - vD)) * 0.5;

    float probability = excess * (1.0 + shear * SPAWN_SHEAR_BOOST)
                      * _SpawnRate * _TexelWorldArea * _DeltaTime;
    // World-keyed roll (frame seed keeps the temporal churn): the accept/reject decision
    // for a given patch of water no longer flickers as the window slides across it.
    if (Rand01(spawnKey, _FrameSeed) >= probability) return;

    // Per-frame budget: count first, back out if over. A few threads may race past
    // the limit; the budget is a soft cap, so that is acceptable.
    uint frameSpawns;
    InterlockedAdd(Counters[COUNTER_FRAME_SPAWNS], 1, frameSpawns);
    if (frameSpawns >= _MaxSpawnPerFrame) return;

    uint cursor;
    InterlockedAdd(Counters[COUNTER_RING_CURSOR], 1, cursor);
    uint slot = cursor & (_Capacity - 1u); // capacity is a power of two

    float4 info = Sim.Load(int3(texel, 0));
    float r0 = Rand01(id.xy, _FrameSeed ^ 0x9E3779B9u);
    float r1 = Rand01(id.xy, _FrameSeed ^ 0x85EBCA6Bu);
    float r2 = Rand01(id.xy, _FrameSeed ^ 0xC2B2AE35u);

    // Surf plunging-lip weight: driven by the coastline's own breaker signal. Evaluated post-roll
    // (after the probability roll) so the transcendental terms run only for the handful of texels
    // that actually spawn this frame.
    float surfLip = 0.0;
    float2 surfToShore = float2(0.0, 0.0);
    if (_ShoreFoamActive > 0.5)
        surfLip = SurfLipAt(texelWorld.xz, surfToShore);

    bool spray = r0 < _SprayChance;
    // The breaking lip always throws: lip spawns are ballistic jet, never floating foam.
    if (surfLip > SURF_SPRAY_MIN_LIP) spray = true;

    // Per-screen-tile spray budget (KWS): spray clumping in one screen region is capped by
    // reserving a slot in a coarse tile grid; over-budget spawns demote to floating foam
    // rather than being lost. Offscreen spawns skip the budget (they cost no overdraw).
    if (spray && _TileBudgetEnabled > 0.5)
    {
        float2 uv; float eyeDepth;
        if (ProjectToScreen(texelWorld, uv, eyeDepth) && all(uv >= 0.0) && all(uv <= 1.0))
        {
            uint2 tile = min((uint2)(uv * TILE_GRID), TILE_GRID - 1);
            uint before;
            InterlockedAdd(TileCounts[tile.y * TILE_GRID + tile.x], 1, before);
            if (before >= _SprayTileCap) spray = false;
        }
    }

    // Surface flow: normal.xz = -gradient(height) = downhill = flow direction.
    float3 flowWorld = mul(VolumeRot(), float3(info.b, 0.0, info.a)) * _FlowDrift;

    FoamParticle particle;
    particle.worldPos = texelWorld;
    particle.worldPos.y = 0.0;
    particle.velocity = flowWorld + float3(_WindDrift.x, 0.0, _WindDrift.y);
    if (spray) particle.velocity.y = _SprayLaunchSpeed * (0.6 + 0.4 * r1);
    // Surf lip jet: throw shoreward along the point's own toward-shore direction; gravity arcs
    // the droplets onto the splash-down zone, where landing converts them to floating churn.
    if (spray && surfLip > SURF_SPRAY_MIN_LIP)
        particle.velocity += float3(surfToShore.x, 0.0, surfToShore.y)
                           * (SURF_SPRAY_THROW_SPEED * surfLip);
    particle.age = 0.0;
    particle.life = lerp(_LifeMin, _LifeMax, r1);
    // Hero-size distribution (KWS): pow biases the roll small, so a few rare sprites land
    // near _SizeMax and read as hero clumps. _SizeHeroPower 1 = the original uniform sizes.
    particle.size = lerp(_SizeMin, _SizeMax, pow(r2, _SizeHeroPower));
    particle.seed = r2;
    particle.kind = spray ? KIND_SPRAY : KIND_SURFACE;
    particle.strength = saturate(foam);
    Particles[slot] = particle;
}

// One thread group per CPU-queued burst request, one thread per droplet candidate: throws
// KIND_SPRAY droplets on a ring around an impact (rigidbody splash, mouse splash). They
// integrate ballistically in Update and land as surface foam, so event splashes share the
// exact tech + look of turbulence-thrown spray - the Shuriken system keeps only the crown.
[numthreads(MAX_BURST_DROPLETS, 1, 1)]
void SpawnBurst(uint3 gid : SV_GroupID, uint3 tid : SV_GroupThreadID)
{
    uint request = gid.x;
    if (request >= _BurstRequestCount) return;
    BurstRequest burst = BurstRequests[request];
    if ((float)tid.x >= burst.count) return;

    uint salt = (uint)(burst.seed * 4294967295.0);
    uint2 key = uint2(tid.x, request);
    float r0 = Rand01(key, salt);
    float r1 = Rand01(key, salt ^ 0x9E3779B9u);
    float r2 = Rand01(key, salt ^ 0x85EBCA6Bu);
    float r3 = Rand01(key, salt ^ 0xC2B2AE35u);

    // Per-frame burst budget (count first, back out if over - the same soft-cap idiom as
    // Spawn): a storm of impact events can no longer flush a quarter-plus of the pool in
    // one frame. Own counter, so bursts never starve behind the turbulence budget.
    uint burstSpawns;
    InterlockedAdd(Counters[COUNTER_BURST_SPAWNS], 1, burstSpawns);
    if (burstSpawns >= _Capacity / BURST_FRAME_CAP_DIVISOR) return;

    uint cursor;
    InterlockedAdd(Counters[COUNTER_RING_CURSOR], 1, cursor);
    uint slot = cursor & (_Capacity - 1u);

    float angle = r0 * 6.2831853;
    float2 dir = float2(cos(angle), sin(angle));
    float ring = burst.radius * BURST_RING_RADIUS_SCALE * r1;

    FoamParticle particle;
    particle.worldPos = float3(burst.center.x + dir.x * ring,
                               BURST_SPAWN_HEIGHT, // y = height ABOVE the local surface
                               burst.center.z + dir.y * ring);
    float outSpeed = burst.outSpeed * lerp(BURST_OUT_JITTER_MIN, BURST_OUT_JITTER_MAX, r2);
    float upSpeed = burst.upSpeed * lerp(BURST_UP_JITTER_MIN, BURST_UP_JITTER_MAX, r3);
    particle.velocity = float3(dir.x * outSpeed, upSpeed, dir.y * outSpeed);
    particle.age = 0.0;
    particle.life = lerp(_LifeMin, _LifeMax, r1);
    // Same hero-size distribution as the turbulence spawns (one look for all droplets).
    particle.size = lerp(_SizeMin, _SizeMax, pow(r2, _SizeHeroPower));
    particle.seed = r0;
    particle.kind = KIND_SPRAY;
    particle.strength = saturate(burst.strength);
    Particles[slot] = particle;
}

// One thread per pool slot: integrate, convert landed spray to surface foam, and
// kill particles that age out or leave the active sim frame.
[numthreads(UPDATE_THREAD_GROUP_SIZE, 1, 1)]
void Update(uint3 id : SV_DispatchThreadID)
{
    uint slot = id.x;
    if (slot >= _Capacity) return;

    FoamParticle particle = Particles[slot];
    if (particle.life <= 0.0) return;

    particle.age += _DeltaTime;

    float2 simNorm = WorldToSimNorm(particle.worldPos);
    float frameEdge = max(abs(simNorm.x), abs(simNorm.y));
    if (frameEdge > 1.0 + FRAME_KILL_MARGIN)
    {
        particle.life = 0.0;
        Particles[slot] = particle;
        return;
    }
    // Edge fade band: accelerate aging toward the frame edge so the life envelope fades
    // the particle out smoothly before the moving window's hard kill can cull it - the
    // sweep of that kill line was one of the "foam follows the camera" causes.
    float fadeStart = 1.0 - FRAME_FADE_BAND;
    if (frameEdge > fadeStart)
    {
        float edgeDepth = saturate((frameEdge - fadeStart) / (FRAME_FADE_BAND + FRAME_KILL_MARGIN));
        particle.age += _DeltaTime * edgeDepth * FRAME_FADE_AGE_BOOST;
    }

    if (particle.age >= particle.life) { particle.life = 0.0; Particles[slot] = particle; return; }

    if (particle.kind == KIND_SPRAY)
    {
        particle.velocity.y -= _Gravity * _DeltaTime;
        particle.worldPos += particle.velocity * _DeltaTime;
        if (particle.worldPos.y <= SPRAY_LANDING_EPSILON && particle.velocity.y < 0.0)
        {
            particle.worldPos.y = 0.0;
            particle.velocity = float3(particle.velocity.x, 0.0, particle.velocity.z) * SPRAY_LANDING_KEEP;
            particle.kind = KIND_SURFACE;
        }
    }
    else
    {
        // Relax the drift toward the driven velocity (local flow + wind): foam has
        // no inertia to speak of, but the relaxation keeps direction changes smooth.
        float4 info = SampleSim(simNorm);
        float3 driven = mul(VolumeRot(), float3(info.b, 0.0, info.a)) * _FlowDrift
                      + float3(_WindDrift.x, 0.0, _WindDrift.y);
#ifdef OCEAN_CREST_FOAM
        // Roll the whitecap foam forward along the wave-travel direction so it moves WITH the
        // breaking crest - but ONLY while the particle is riding an active whitecap. Applied
        // as a constant field (v1) this conveyor-belted the ENTIRE floating population along
        // the swell heading ("all the foam drifts off", worst near shore); gated by the local
        // whitecap amount, foam rolls with the crest that made it, then parks and decays.
        driven += float3(_CrestRoll.x, 0.0, _CrestRoll.y) * OceanCrestFoamAt(particle.worldPos.xz);
#endif
        // Curl + clumping (KWS): a divergence-free swirl (gradient rotated 90 degrees) keeps
        // floating foam alive, and a gentle pull UP the noise gradient gathers it into
        // streaks/patches instead of a uniform sprinkle. The field drifts slowly so clumps
        // form, wander and dissolve.
        float2 noiseGrad = FoamNoiseGrad(particle.worldPos.xz * FOAM_NOISE_SCALE
                                         + _FoamTime * FOAM_NOISE_DRIFT);
        driven += float3(noiseGrad.y, 0.0, -noiseGrad.x) * FOAM_CURL_SPEED
                + float3(noiseGrad.x, 0.0, noiseGrad.y) * FOAM_CLUMP_SPEED;
        particle.velocity = lerp(particle.velocity, driven, saturate(_Drag * _DeltaTime));
        particle.velocity.y = 0.0;
        particle.worldPos += particle.velocity * _DeltaTime;
        particle.worldPos.y = 0.0;
    }

    Particles[slot] = particle;
}

// One thread per density texel: reset for this frame's splats.
[numthreads(UPDATE_THREAD_GROUP_SIZE, 1, 1)]
void ClearDensity(uint3 id : SV_DispatchThreadID)
{
    uint texelCount = _DensitySize.x * _DensitySize.y;
    if (id.x >= texelCount) return;
    DensityBuffer[id.x] = 0u;
    DensityDepth[id.x] = DEPTH_CLEAR;
}

// One thread per pool slot (KWS RenderParticlesToScreenSpaceBuffer): every live FLOATING
// particle splats its life-enveloped weight into the screen-space density buffer with
// InterlockedAdd, and its eye depth with InterlockedMin (occlusion + soft fade in the
// composite). Spray stays on the textured-quad draw. Thousands of particles become one
// cheap density field instead of overlapping transparent quads.
[numthreads(UPDATE_THREAD_GROUP_SIZE, 1, 1)]
void RasterizeDensity(uint3 id : SV_DispatchThreadID)
{
    uint slot = id.x;
    if (slot >= _Capacity) return;

    FoamParticle particle = Particles[slot];
    if (particle.life <= 0.0 || particle.age >= particle.life) return;
    if (particle.kind == KIND_SPRAY) return;

    float2 simNorm = WorldToSimNorm(particle.worldPos);
    float3 world = particle.worldPos;
    world.y = SurfaceWorldY(world, simNorm);

    float2 uv; float eyeDepth;
    if (!ProjectToScreen(world, uv, eyeDepth)) return;
    if (any(uv < 0.0) || any(uv > 1.0)) return;

    float weight = FoamParticleEnvelope(particle.age, particle.life) * particle.strength;
    if (weight <= 0.0) return;

    uint fixedWeight = max(1u, (uint)(weight * _DensityWeightScale));
    uint depthMm = (uint)(eyeDepth * DEPTH_TO_MM);

    // Projected footprint in density texels (vertical focal term / eye depth), clamped so
    // the loop stays bounded; the composite's dilation closes pinholes beyond the clamp.
    float radiusPx = particle.size * _DensityProj11 * (float)_DensitySize.y * 0.5 / eyeDepth;
    int radius = clamp((int)radiusPx, 1, SPLAT_RADIUS_MAX);
    int radiusSq = radius * radius;

    int2 centre = (int2)(uv * (float2)_DensitySize);
    for (int dy = -radius; dy <= radius; dy++)
        for (int dx = -radius; dx <= radius; dx++)
        {
            if (dx * dx + dy * dy > radiusSq) continue;
            int2 p = centre + int2(dx, dy);
            if (any(p < 0) || p.x >= (int)_DensitySize.x || p.y >= (int)_DensitySize.y) continue;
            uint index = (uint)p.y * _DensitySize.x + (uint)p.x;
            InterlockedAdd(DensityBuffer[index], fixedWeight);
            InterlockedMin(DensityDepth[index], depthMm);
        }
}
